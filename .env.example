# .env.example — Template public des variables d'environnement
#
# Ce fichier est un modèle sans valeurs réelles. Il peut être commité sur Git.
# Pour démarrer : copie ce fichier, renomme-le .env, et remplis tes vraies clés.

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Notion ───────────────────────────────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=

# ─── Google / YouTube ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_API_KEY=

# ─── Vercel ───────────────────────────────────────────────────────────────────
VERCEL_TOKEN=

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
