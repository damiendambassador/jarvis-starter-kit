# Supabase — copie ce fichier en .env.local et remplis les valeurs
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_ici

# Resend — pour l'envoi d'emails
RESEND_API_KEY=re_votre_api_key_ici

# Email du chauffeur par défaut (pour les notifications)
DEFAULT_DRIVER_EMAIL=damiendambassador@gmail.com
