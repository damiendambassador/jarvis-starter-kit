# ── Supabase ──────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role : NE JAMAIS exposer côté client. Utilisé seulement dans les routes API serveur.
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Maps ───────────────────────────────────────────
# Clé CLIENT (carte + autocomplete). Restreindre par "Referrer HTTP" au domaine.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Map ID requis par les Advanced Markers. "DEMO_MAP_ID" fonctionne pour démarrer ;
# créer le vôtre dans Google Cloud → Map Management pour personnaliser le style.
NEXT_PUBLIC_MAP_ID=DEMO_MAP_ID
# Clé SERVEUR (géocodage + distance). Restreindre par API (Geocoding, Distance Matrix, Directions).
GOOGLE_MAPS_SERVER_KEY=
